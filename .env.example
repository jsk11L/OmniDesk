# ─────────────────────────────────────────────────────────────
# OmniDesk — docker-compose environment.
# Copy to `.env` and edit. Used by `docker compose up -d`.
# (For non-Docker local backend dev see backend/.env.example.)
# ─────────────────────────────────────────────────────────────

# ─── Database (the bundled postgres service) ───
POSTGRES_USER=omnidesk
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=omnidesk
# If you use an EXTERNAL managed Postgres, set DATABASE_URL on the backend
# service instead and you can remove the postgres service from compose:
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# ─── Auth ───
# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changeme_min_32_chars_random
JWT_REFRESH_SECRET=changeme_DIFFERENT_32_chars_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── URLs ───
FRONTEND_URL=https://your-domain.example

# ─── Web push (optional but recommended) ───
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY is baked into the frontend bundle at build time (build arg).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ─── Email (optional; without it MailService runs in mock/console mode) ───
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@your-domain.example

# ─── Uploads ───
UPLOADS_MAX_BYTES=5242880               # 5 MiB per individual file
UPLOADS_QUOTA_PER_USER_BYTES=524288000  # 500 MiB per user (enforced in Block 2)

# ─── Public multi-user (wired up in Block 2; safe defaults here) ───
REGISTRATION_OPEN=true
CAPTCHA_PROVIDER=none                   # hcaptcha | turnstile | none
CAPTCHA_SITE_KEY=                       # baked into the frontend bundle (build arg)
CAPTCHA_SECRET=
TERMS_VERSION=2026-05

# ─── User defaults ───
USER_DEFAULT_TIMEZONE=UTC

# ─── Account lifecycle ───
SOFT_DELETE_DAYS=30                     # grace days before a soft-deleted account is purged

# ─── Operational ───
NODE_ENV=production

# ─── Backups (used by scripts/backup.sh) ───
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
