generator client {
  provider = "prisma-client-js"
}

// Generates plain TypeScript interfaces for the models into the shared
// workspace package (D-011, Stage 1). Plain interfaces — no zod, no
// @prisma/client import — so the non-Prisma frontend can consume them type-only
// to kill frontend↔backend drift. Dates are emitted as strings to match the
// JSON the REST API actually sends. Backend Zod DTOs are a separate Stage 2.
generator interfaces {
  provider     = "prisma-generator-typescript-interfaces"
  output       = "../../shared/src/generated/models.ts"
  modelType    = "interface"
  enumType     = "stringUnion"
  dateType     = "string"
  jsonType     = "unknown"
  relations    = "none"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH & USER
// ─────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  displayName         String?
  avatarUrl           String?
  isEmailVerified     Boolean   @default(false)
  verificationToken   String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  timezone            String?
  deletedAt           DateTime?

  // Block 2 · public multi-user
  isAdmin             Boolean   @default(false)
  isSuspended         Boolean   @default(false)
  acceptedTermsAt     DateTime?
  termsVersion        String?
  uploadBytesUsed     BigInt    @default(0)
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // 2FA (TOTP)
  totpSecret          String?
  totpEnabledAt       DateTime?
  totpBackupCodes     String[]

  // Notification preferences (Block 3) — do-not-disturb window, local "HH:MM"
  dndStart            String?
  dndEnd              String?
  quietDays           Int[]     @default([]) // 0=Sun … 6=Sat; no push on these days

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  pushSubscriptions PushSubscription[]
  calendarEvents    CalendarEvent[]
  calendarSettings  CalendarSettings?
  lists             List[]
  notes             Note[]
  todoBoards        TodoBoard[]
  habits            Habit[]
  financeBoards     FinanceBoard[]
  favorites         Favorite[]
  notifications     NotificationConfig[]
  themes            Theme[]              @relation("ThemeOwner")
  activeThemeId     String?
  activeTheme       Theme?               @relation("ActiveTheme", fields: [activeThemeId], references: [id])
}

/// Sidebar shortcut to a user-chosen entity (list, note…). Stores only the
/// reference; label + icon are resolved from the target at read time so they
/// stay in sync, and stale favorites (deleted targets) are filtered out.
model Favorite {
  id        String       @id @default(uuid())
  userId    String
  kind      FavoriteKind
  entityId  String
  position  Int          @default(0)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, entityId])
  @@index([userId, position])
}

enum FavoriteKind {
  LIST
  NOTE
}

model PushSubscription {
  id          String    @id @default(uuid())
  userId      String
  endpoint    String    @unique
  p256dh      String
  auth        String
  userAgent   String?
  deviceLabel String?
  platform    String? // 'desktop' | 'mobile' | 'tablet' | 'unknown'
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Significant/destructive event log (Block 2, §3.3.3). Intentionally has no
// relation to User so entries survive a hard account deletion for forensics.
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ─────────────────────────────────────────
// NOTIFICATIONS (sistema central)
// ─────────────────────────────────────────

model NotificationConfig {
  id            String                @id @default(uuid())
  userId        String
  title         String
  message       String
  iconUrl       String?
  accentColor   String                @default("#6366f1")
  triggerType   NotificationTrigger
  scheduledAt   DateTime?
  recurringRule String?
  isRecurring   Boolean               @default(false)
  channels      NotificationChannel[]
  isActive      Boolean               @default(true)
  isFired       Boolean               @default(false)
  lastFiredAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  user             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvents   CalendarEventNotification[]
  notes            NoteNotification[]
  listItems        ListItemNotification[]
  todoItems        TodoItemNotification[]
  habits           HabitNotification[]
  wishlistItems    WishlistItemNotification[]
  plannedPurchases PlannedPurchaseNotification[]
  savingsGoals     SavingsGoalNotification[]
  inAppQueue       InAppNotification[]
}

enum NotificationTrigger {
  MANUAL
  SCHEDULED
  RECURRING
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

model InAppNotification {
  id             String   @id @default(uuid())
  userId         String
  notificationId String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CALENDAR
// ─────────────────────────────────────────

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean  @default(false)
  color       String   @default("#6366f1")
  location    String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications CalendarEventNotification[]

  @@index([userId, startDate])
}

model CalendarEventNotification {
  id             String @id @default(uuid())
  eventId        String
  notificationId String
  minutesBefore  Int    @default(15)

  event        CalendarEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model CalendarSettings {
  id          String              @id @default(uuid())
  userId      String              @unique
  size        CalendarSize        @default(NORMAL)
  borderStyle CalendarBorderStyle @default(ROUNDED)
  firstDay    Int                 @default(1)
  defaultView String              @default("dayGridMonth")
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CalendarSize {
  COMPACT
  NORMAL
  COMFORTABLE
}

enum CalendarBorderStyle {
  SQUARE
  ROUNDED
}

// ─────────────────────────────────────────
// LISTS (Bibliotecas enriquecidas)
// ─────────────────────────────────────────

model List {
  id               String        @id @default(uuid())
  userId           String
  name             String
  description      String?
  icon             String?
  coverImageUrl    String?
  defaultView      ListViewType  @default(GRID)
  defaultSortField String?
  defaultSortDir   SortDirection @default(ASC)
  gridConfig       Json          @default("{}")
  viewConfig       Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  ListItem[]
  fields ListField[]
  tags   ListTag[]
}

enum ListViewType {
  GRID
  TABLE
  GALLERY
  LIST
}

enum SortDirection {
  ASC
  DESC
}

model ListField {
  id           String        @id @default(uuid())
  listId       String
  name         String
  fieldType    ListFieldType
  isRequired   Boolean       @default(false)
  position     Int           @default(0)
  options      Json?
  defaultValue String?

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)
}

enum ListFieldType {
  TEXT
  NUMBER
  DATE
  URL
  BOOLEAN
  SELECT
  MULTI_SELECT
  RATING
  IMAGE_URL
}

model ListTag {
  id     String @id @default(uuid())
  listId String
  name   String
  color  String @default("#94a3b8")

  list  List          @relation(fields: [listId], references: [id], onDelete: Cascade)
  items ListItemTag[]
}

model ListItem {
  id           String   @id @default(uuid())
  listId       String
  title        String
  customFields Json     @default("{}")
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  list          List                   @relation(fields: [listId], references: [id], onDelete: Cascade)
  tags          ListItemTag[]
  notifications ListItemNotification[]
}

model ListItemTag {
  itemId String
  tagId  String

  item ListItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  ListTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

// ─────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────

model Note {
  id            String   @id @default(uuid())
  userId        String
  title         String
  content       String   @default("")
  plainText     String?
  description   String?  @db.VarChar(280)
  icon          String?
  coverImageUrl String?
  isPinned      Boolean  @default(false)
  tags          String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications NoteNotification[]

  @@index([userId, updatedAt])
}

model NoteNotification {
  id             String @id @default(uuid())
  noteId         String
  notificationId String

  note         Note               @relation(fields: [noteId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// ATTACHABLE NOTIFICATIONS · 6 new entities (Block 3, §3.4.3)
// ─────────────────────────────────────────

model ListItemNotification {
  id             String @id @default(uuid())
  listItemId     String
  notificationId String

  listItem     ListItem           @relation(fields: [listItemId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model TodoItemNotification {
  id             String @id @default(uuid())
  todoItemId     String
  notificationId String
  minutesBefore  Int? // fires N minutes before the item's dueDate

  todoItem     TodoItem           @relation(fields: [todoItemId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model HabitNotification {
  id             String @id @default(uuid())
  habitId        String
  notificationId String
  timeOfDay      String? // "HH:MM" in the user's local time

  habit        Habit              @relation(fields: [habitId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model WishlistItemNotification {
  id             String @id @default(uuid())
  wishlistItemId String
  notificationId String

  wishlistItem WishlistItem       @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model PlannedPurchaseNotification {
  id                String @id @default(uuid())
  plannedPurchaseId String
  notificationId    String
  daysBefore        Int? // fires N days before the targetDate

  plannedPurchase PlannedPurchase    @relation(fields: [plannedPurchaseId], references: [id], onDelete: Cascade)
  notification    NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model SavingsGoalNotification {
  id             String @id @default(uuid())
  savingsGoalId  String
  notificationId String

  savingsGoal  SavingsGoal        @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
  notification NotificationConfig @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// TO-DO (Kanban)
// ─────────────────────────────────────────

model TodoBoard {
  id        String   @id @default(uuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns TodoColumn[]
}

model TodoColumn {
  id                 String  @id @default(uuid())
  boardId            String
  name               String
  color              String  @default("#94a3b8")
  position           Int     @default(0)
  isCompletionColumn Boolean @default(false)

  board TodoBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items TodoItem[]
}

model TodoItem {
  id          String       @id @default(uuid())
  columnId    String
  title       String
  description String?
  dueDate     DateTime?
  hasDueDate  Boolean      @default(false)
  priority    TodoPriority @default(MEDIUM)
  hasPriority Boolean      @default(false)
  tags        String[]     @default([])
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  column        TodoColumn             @relation(fields: [columnId], references: [id], onDelete: Cascade)
  notifications TodoItemNotification[]
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────────
// HABITS
// ─────────────────────────────────────────

model Habit {
  id            String   @id @default(uuid())
  userId        String
  name          String
  description   String?
  icon          String?
  color         String   @default("#6366f1")
  activeDays    Int[]    @default([1, 2, 3, 4, 5, 6, 0])
  weeklyGoal    Int?
  goalPeriod    GoalPeriod?
  goalTarget    Int?
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  perfectWeeks  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries       HabitEntry[]
  notifications HabitNotification[]
}

model HabitEntry {
  id        String           @id @default(uuid())
  habitId   String
  date      DateTime         @db.Date
  status    HabitEntryStatus
  notes     String?
  createdAt DateTime         @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

enum HabitEntryStatus {
  DONE
  MISSED
  RECOVERED
  REST
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

// ─────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────

model FinanceBoard {
  id        String   @id @default(uuid())
  userId    String
  name      String
  currency  String   @default("USD")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories            FinanceCategory[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  wishlistItems         WishlistItem[]
  plannedPurchases      PlannedPurchase[]
  savingsGoals          SavingsGoal[]
}

model FinanceCategory {
  id           String              @id @default(uuid())
  boardId      String
  name         String
  color        String              @default("#94a3b8")
  icon         String?
  categoryType FinanceCategoryType

  board                 FinanceBoard           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  plannedPurchases      PlannedPurchase[]
}

enum FinanceCategoryType {
  INCOME
  EXPENSE
}

model Transaction {
  id         String              @id @default(uuid())
  boardId    String
  categoryId String?
  title      String
  amount     Float
  type       FinanceCategoryType
  date       DateTime
  notes      String?
  tags       String[]            @default([])
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  board    FinanceBoard     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  category FinanceCategory? @relation(fields: [categoryId], references: [id])

  @@index([boardId, date])
}

/// A template that the scheduler materializes into real Transactions on each
/// due date (subscriptions, salary, rent…). `nextRun` is advanced by `frequency`
/// after each materialization; `isActive=false` pauses it without deleting.
model RecurringTransaction {
  id         String              @id @default(uuid())
  boardId    String
  categoryId String?
  title      String
  amount     Float
  type       FinanceCategoryType
  frequency  RecurringFrequency  @default(MONTHLY)
  notes      String?
  tags       String[]            @default([])
  nextRun    DateTime
  lastRun    DateTime?
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  board    FinanceBoard     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  category FinanceCategory? @relation(fields: [categoryId], references: [id])

  @@index([isActive, nextRun])
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id         String       @id @default(uuid())
  boardId    String
  categoryId String?
  name       String
  amount     Float
  period     BudgetPeriod @default(MONTHLY)
  createdAt  DateTime     @default(now())

  board    FinanceBoard     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  category FinanceCategory? @relation(fields: [categoryId], references: [id])
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  ANNUAL
}

model WishlistItem {
  id             String           @id @default(uuid())
  boardId        String
  title          String
  description    String?
  imageUrl       String?
  estimatedPrice Float?
  currency       String           @default("USD")
  url            String?
  category       String?
  priority       WishlistPriority @default(MEDIUM)
  isArchived     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  board         FinanceBoard               @relation(fields: [boardId], references: [id], onDelete: Cascade)
  notifications WishlistItemNotification[]
}

enum WishlistPriority {
  LOW
  MEDIUM
  HIGH
}

model PlannedPurchase {
  id          String    @id @default(uuid())
  boardId     String
  title       String
  amount      Float
  currency    String    @default("USD")
  targetDate  DateTime
  categoryId  String?
  isPurchased Boolean   @default(false)
  purchasedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  board         FinanceBoard                  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  category      FinanceCategory?              @relation(fields: [categoryId], references: [id])
  notifications PlannedPurchaseNotification[]
}

model SavingsGoal {
  id            String    @id @default(uuid())
  boardId       String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  currency      String    @default("USD")
  targetDate    DateTime?
  icon          String?
  color         String    @default("#22c55e")
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  board         FinanceBoard              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  contributions SavingsContribution[]
  notifications SavingsGoalNotification[]
}

model SavingsContribution {
  id        String   @id @default(uuid())
  goalId    String
  amount    Float
  date      DateTime @default(now())
  notes     String?

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// THEMES
// ─────────────────────────────────────────

model Theme {
  id                String   @id @default(uuid())
  userId            String
  name              String
  isDefault         Boolean  @default(false)
  isDark            Boolean  @default(true)
  colorPrimary      String   @default("#6366f1")
  colorSecondary    String   @default("#8b5cf6")
  colorBackground   String   @default("#0f0f0f")
  colorSurface      String   @default("#1a1a1a")
  colorSurfaceHover String   @default("#242424")
  colorBorder       String   @default("#2e2e2e")
  colorText         String   @default("#e5e5e5")
  colorTextMuted    String   @default("#71717a")
  colorAccent       String   @default("#f59e0b")
  colorDanger       String   @default("#ef4444")
  colorSuccess      String   @default("#22c55e")
  fontFamily        String   @default("'Inter', sans-serif")
  borderRadius      String   @default("0.5rem")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  owner          User   @relation("ThemeOwner", fields: [userId], references: [id], onDelete: Cascade)
  activeForUsers User[] @relation("ActiveTheme")
}
