# ─────────────────────────────────────────────────────────────
# OmniDesk backend environment.
# Copy to `.env` and adjust. The backend validates these at boot
# (src/config/env.validation.ts) and refuses to start if invalid.
# ─────────────────────────────────────────────────────────────

# Runtime ------------------------------------------------------
NODE_ENV=development           # development | test | production
PORT=3000                      # HTTP port the API listens on

# Database -----------------------------------------------------
# PostgreSQL connection string used by Prisma. REQUIRED.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omnidesk?schema=public"

# Auth ---------------------------------------------------------
# REQUIRED. Min 16 chars. In production they must not look like a
# placeholder and must differ from each other.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change_me_dev_secret_at_least_16_chars"
JWT_REFRESH_SECRET="change_me_dev_refresh_secret_16_chars"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend / CORS ----------------------------------------------
FRONTEND_URL=http://localhost:4200

# Seed ---------------------------------------------------------
SEED_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001

# Mail (optional - mock mode when host/credentials absent) -----
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM="OmniDesk <no-reply@omnidesk.app>"

# Uploads ------------------------------------------------------
UPLOADS_DIR=./uploads
UPLOADS_BASE_URL=/uploads
UPLOADS_MAX_BYTES=5242880

# Web push (optional - push disabled when absent/placeholder) --
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Account lifecycle --------------------------------------------
SOFT_DELETE_DAYS=30
